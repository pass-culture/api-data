# Remote environment overrides template
# Copy this file to .env.dev, .env.stg or .env.prod and fill in the values.
# Usage:
#   make streamlit-remote DEPLOY_ENV=dev|stg|prod
#   make access-remote-swagger DEPLOY_ENV=dev|stg|prod
#   make get-api-token DEPLOY_ENV=dev|stg|prod

# Remote API URLs
REMOTE_API_URL=
REMOTE_API_V1_URL=

# SOCKS5 proxy port used for the SSH tunnel (default: 1080)
REMOTE_API_SOCKS_PORT=1080

# API authentication token
REMOTE_API_TOKEN=

# SSH tunnel configuration (override only if different from .env)
GCP_IAP_BASTION_INSTANCE_NAME=
GCP_BASTION_PROJECT=

# GCP Secret Manager — used by make get-api-token
GCP_SECRET_PROJECT=
API_RECO_TOKEN_SECRET_NAME=
